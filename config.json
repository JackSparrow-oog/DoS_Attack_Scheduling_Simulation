{
  "project_name": "DoS attack schedule independent reproduction",
  "paper": {
    "title": "DoS attack schedules for remote state estimation under multi-sensor round-robin protocol",
    "journal": "Systems & Control Letters 204 (2025) 106190",
    "doi": "10.1016/j.sysconle.2025.106190"
  },
  "model": {
    "A": [[2.0, 0.0], [0.0, 0.8]],
    "Sigma_w": [[0.1, 0.0], [0.0, 0.2]],
    "C": [
      [[1.0, 0.0], [0.0, 0.3]],
      [[0.6, 0.0], [0.0, 0.8]]
    ],
    "Sigma_v": [
      [[1.0, 0.0], [0.0, 1.0]],
      [[0.7, 0.0], [0.0, 1.0]]
    ],
    "Sigma_0_assumed": [[1.0, 0.0], [0.0, 1.0]]
  },
  "channel": {
    "sensor_channel_probability_beta": [0.3, 0.7],
    "attacker_channel_probability_eta": [0.6, 0.4],
    "sensor_power_ps": [0.5, 0.6],
    "attacker_power_pa": [0.3, 0.3],
    "interference_multiplier_assumed": 5.0,
